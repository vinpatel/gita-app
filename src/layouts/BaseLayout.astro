---
import '../styles/global.css';
import '@fontsource-variable/source-serif-4';
import '@fontsource-variable/inter';
import '@fontsource-variable/noto-sans-devanagari/wght.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: string;
  /** If set, used verbatim. Otherwise built from Astro.url + Astro.site. */
  canonical?: string;
}

const {
  title,
  description = 'The Bhagavad Gītā — Every shloka becomes actionable wisdom for your life',
  image = '/og-default.png',
  ogType = 'website',
  canonical,
} = Astro.props;

const goatcounter = import.meta.env.PUBLIC_GOATCOUNTER_CODE;

const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? 'https://bhagavad.net';
const canonicalURL = canonical ?? `${siteOrigin}${Astro.url.pathname}`;
const absoluteImage = image.startsWith('http') ? image : `${siteOrigin}${image}`;
const fullTitle = `${title} | The Bhagavad Gītā`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="The Bhagavad Gītā" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />

    <ClientRouter />
    <title>{fullTitle}</title>

    <slot name="head" />

    {goatcounter && (
      <script
        is:inline
        async
        data-goatcounter={`https://${goatcounter}.goatcounter.com/count`}
        src="//gc.zgo.at/count.js"
      ></script>
    )}
  </head>
  <body class="min-h-screen flex flex-col bg-[--color-bg] text-[--color-text]" transition:animate="fade">

    <slot />

    <footer class="border-t border-[--color-border] py-10 text-center mt-auto">
      <p class="font-[--font-devanagari] text-[--color-text-3] mb-2" style="font-size: 110%;">
        कर्मण्येवाधिकारस्ते मा फलेषु कदाचन
      </p>
      <p class="text-xs text-[--color-text-3] tracking-wide">
        Multi-tradition synthesis &middot; IAST transliteration &middot; Open source
      </p>
      <a href={`${import.meta.env.BASE_URL}learn-sanskrit/`} class="inline-block mt-3 text-xs text-[--color-accent] hover:text-[--color-text-2] transition-colors tracking-wide">
        Learn Sanskrit in 14 Days &rarr;
      </a>
    </footer>

  </body>
</html>
