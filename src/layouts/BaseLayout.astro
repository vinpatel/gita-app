---
import '../styles/global.css';
import '@fontsource-variable/source-serif-4';
import '@fontsource-variable/inter';
import '@fontsource-variable/noto-sans-devanagari/wght.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'The Bhagavad Gītā — Every shloka becomes actionable wisdom for your life' } = Astro.props;
const goatcounter = import.meta.env.PUBLIC_GOATCOUNTER_CODE;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <ClientRouter />
    <title>{title} | The Bhagavad Gītā</title>
    {goatcounter && (
      <script
        is:inline
        async
        data-goatcounter={`https://${goatcounter}.goatcounter.com/count`}
        src="//gc.zgo.at/count.js"
      ></script>
    )}
  </head>
  <body class="min-h-screen flex flex-col bg-[--color-bg] text-[--color-text]" transition:animate="fade">

    <slot />

    <footer class="border-t border-[--color-border] py-10 text-center mt-auto">
      <p class="font-[--font-devanagari] text-[--color-text-3] mb-2" style="font-size: 110%;">
        कर्मण्येवाधिकारस्ते मा फलेषु कदाचन
      </p>
      <p class="text-xs text-[--color-text-3] tracking-wide">
        Multi-tradition synthesis &middot; IAST transliteration &middot; Open source
      </p>
      <a href={`${import.meta.env.BASE_URL}learn-sanskrit/`} class="inline-block mt-3 text-xs text-[--color-accent] hover:text-[--color-text-2] transition-colors tracking-wide">
        Learn Sanskrit in 14 Days &rarr;
      </a>
    </footer>

  </body>
</html>
