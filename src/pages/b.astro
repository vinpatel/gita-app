---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allShlokas = await getCollection('chapters');
const chaptersWithData = new Set(allShlokas.map((s) => s.data.chapter));

const chapterMeta = [
  { num: 1, name: 'Arjuna\'s Dilemma', sanskrit: 'अर्जुनविषादयोग', verses: 47,
    color: '#64748b',
    lesson: 'Inner conflict is the starting point of all growth' },
  { num: 2, name: 'The Path of Knowledge', sanskrit: 'सांख्ययोग', verses: 72,
    color: '#6366f1',
    lesson: 'Stop identifying with what changes' },
  { num: 3, name: 'The Path of Action', sanskrit: 'कर्मयोग', verses: 43,
    color: '#f97316',
    lesson: 'Act without obsessing over results' },
  { num: 4, name: 'Knowledge & Renunciation', sanskrit: 'ज्ञानकर्मसंन्यासयोग', verses: 42,
    color: '#f59e0b',
    lesson: 'Knowledge burns karma like fire burns fuel' },
  { num: 5, name: 'Renunciation of Action', sanskrit: 'कर्मसंन्यासयोग', verses: 29,
    color: '#14b8a6',
    lesson: 'Be free while fully engaged in the world' },
  { num: 6, name: 'The Path of Meditation', sanskrit: 'ध्यानयोग', verses: 47,
    color: '#8b5cf6',
    lesson: 'The mind is your greatest ally or worst enemy' },
  { num: 7, name: 'Knowledge & Realization', sanskrit: 'ज्ञानविज्ञानयोग', verses: 30,
    color: '#06b6d4',
    lesson: 'One reality in infinite forms' },
  { num: 8, name: 'The Imperishable Absolute', sanskrit: 'अक्षरब्रह्मयोग', verses: 28,
    color: '#a855f7',
    lesson: 'Your last thought shapes what comes next' },
  { num: 9, name: 'Royal Knowledge', sanskrit: 'राजविद्याराजगुह्ययोग', verses: 34,
    color: '#f43f5e',
    lesson: 'A leaf offered with love reaches the divine' },
  { num: 10, name: 'Divine Manifestations', sanskrit: 'विभूतियोग', verses: 42,
    color: '#10b981',
    lesson: 'Everything extraordinary is a glimpse of the infinite' },
  { num: 11, name: 'The Cosmic Vision', sanskrit: 'विश्वरूपदर्शनयोग', verses: 55,
    color: '#d946ef',
    lesson: 'Reality is vaster than the mind can hold' },
  { num: 12, name: 'The Path of Devotion', sanskrit: 'भक्तियोग', verses: 20,
    color: '#ec4899',
    lesson: 'Love is the fastest path' },
  { num: 13, name: 'The Field & The Knower', sanskrit: 'क्षेत्रक्षेत्रज्ञविभागयोग', verses: 35,
    color: '#0ea5e9',
    lesson: 'You are the awareness, not the body' },
  { num: 14, name: 'The Three Gunas', sanskrit: 'गुणत्रयविभागयोग', verses: 27,
    color: '#65a30d',
    lesson: 'Clarity, passion, inertia — name them, then rise above' },
  { num: 15, name: 'The Supreme Person', sanskrit: 'पुरुषोत्तमयोग', verses: 20,
    color: '#eab308',
    lesson: 'Cut the tree of attachment with detachment' },
  { num: 16, name: 'Divine & Demonic Natures', sanskrit: 'दैवासुरसम्पद्विभागयोग', verses: 24,
    color: '#ef4444',
    lesson: 'Desire, anger, greed — three gates to self-destruction' },
  { num: 17, name: 'Three Kinds of Faith', sanskrit: 'श्रद्धात्रयविभागयोग', verses: 28,
    color: '#3b82f6',
    lesson: 'Your faith shapes what you eat, give, and become' },
  { num: 18, name: 'Liberation Through Surrender', sanskrit: 'मोक्षसंन्यासयोग', verses: 78,
    color: '#d97706',
    lesson: 'Surrender everything — then act with full freedom' },
];

const chapters = chapterMeta.map((ch) => ({
  ...ch,
  available: chaptersWithData.has(ch.num),
  loadedVerses: allShlokas.filter((s) => s.data.chapter === ch.num).length,
}));

const totalVerses = allShlokas.length;
---
<BaseLayout title="Home" description="The Bhagavad Gītā — 18 life lessons from 700 verses. What each chapter actually teaches you.">

  <style>
    .hero-gradient {
      background: linear-gradient(135deg, #1e1a14 0%, #332D24 30%, #4A4035 60%, #C4832D 100%);
    }
    @keyframes gradient-shift {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }
    .animate-gradient {
      background-size: 200% 200%;
      animation: gradient-shift 8s ease infinite;
    }
    .lesson-item {
      transition: all 0.2s ease;
    }
    .lesson-item:hover {
      background-color: rgba(0,0,0,0.02);
    }
    .lesson-dot {
      transition: transform 0.2s ease;
    }
    .lesson-item:hover .lesson-dot {
      transform: scale(1.3);
    }
    .lesson-item:hover .lesson-number {
      opacity: 1;
    }
    .lesson-item:hover .lesson-text {
      color: var(--item-color);
    }
    .lesson-item:hover .lesson-arrow {
      opacity: 1;
      transform: translateX(0);
    }
    .feature-card {
      background: linear-gradient(135deg, rgba(255,255,255,0.8), rgba(255,255,255,0.4));
      backdrop-filter: blur(10px);
    }
  </style>

  <main class="flex-1">

    <!-- Hero — dark gradient -->
    <section class="hero-gradient animate-gradient relative overflow-hidden">
      <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22 opacity=%22.15%22>%E0%A5%90</text></svg>'); background-size: 120px; background-repeat: repeat;"></div>
      <div class="relative max-w-3xl mx-auto px-6 pt-20 sm:pt-28 pb-16 sm:pb-24">
        <p class="font-[--font-devanagari] text-xl sm:text-2xl text-white/40 mb-4 animate-fade-in">श्रीमद्भगवद्गीता</p>
        <h1 class="font-[--font-display] text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-light text-white leading-[1.05] tracking-tight animate-slide-up">
          The Bhagavad<br class="hidden sm:block" /> Gītā
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-white/60 leading-relaxed max-w-xl animate-fade-in">
          A catalog of 18 life lessons — teachings — that Krishna gave Arjuna on the battlefield 5,000 years ago. Still the best advice you'll ever get.
        </p>
        <div class="mt-8 flex flex-wrap gap-3 animate-fade-in">
          <span class="px-4 py-1.5 rounded-full bg-white/10 text-sm text-white/70 backdrop-blur-sm">{totalVerses} verses</span>
          <span class="px-4 py-1.5 rounded-full bg-white/10 text-sm text-white/70 backdrop-blur-sm">8 traditions</span>
          <span class="px-4 py-1.5 rounded-full bg-white/10 text-sm text-white/70 backdrop-blur-sm">4 life pillars</span>
          <a href={`${import.meta.env.BASE_URL}learn-sanskrit/`} class="px-4 py-1.5 rounded-full bg-[--color-saffron]/80 text-sm text-white hover:bg-[--color-saffron] transition-colors backdrop-blur-sm">Learn Sanskrit</a>
        </div>
      </div>
    </section>

    <!-- 18 Lessons — 37signals style numbered list with color accents -->
    <section class="max-w-3xl mx-auto px-6 pt-16 sm:pt-24 pb-8">
      <h2 class="font-[--font-display] text-3xl sm:text-4xl text-[--color-warm-800] mb-2">18 lessons for life</h2>
      <p class="text-[--color-warm-500] text-lg mb-2">Each chapter is one teaching. Each teaching changes how you see the world.</p>
    </section>

    <section class="max-w-3xl mx-auto px-6 pb-16 sm:pb-24">
      <ol class="border-t border-[--color-warm-200]">
        {chapters.map((ch) => (
          ch.available ? (
            <li>
              <a href={`${import.meta.env.BASE_URL}chapter/${ch.num}/`}
                 class="lesson-item flex items-center gap-5 sm:gap-6 py-5 sm:py-6 border-b border-[--color-warm-200]/70 px-3 sm:px-4 -mx-3 sm:-mx-4 rounded-lg cursor-pointer"
                 style={`--item-color: ${ch.color}`}>
                <!-- Colored dot -->
                <div class="shrink-0 flex items-center gap-3 sm:gap-4">
                  <div class="lesson-dot w-3 h-3 rounded-full shrink-0" style={`background-color: ${ch.color}`}></div>
                  <span class="lesson-number font-[--font-display] text-2xl sm:text-3xl font-light text-[--color-warm-300] opacity-60 w-10 sm:w-12 tabular-nums text-right">
                    {String(ch.num).padStart(2, '0')}
                  </span>
                </div>
                <!-- Lesson text -->
                <div class="flex-1 min-w-0">
                  <p class="lesson-text font-[--font-display] text-xl sm:text-2xl md:text-[1.65rem] text-[--color-warm-800] leading-snug transition-colors duration-200">
                    {ch.lesson}
                  </p>
                  <p class="mt-1 text-sm text-[--color-warm-400]">
                    <span class="font-medium">{ch.name}</span>
                    <span class="font-[--font-devanagari] ml-2 text-[--color-warm-300]">{ch.sanskrit}</span>
                  </p>
                </div>
                <!-- Arrow -->
                <span class="lesson-arrow text-lg opacity-0 -translate-x-2 transition-all duration-200 shrink-0 hidden sm:block" style={`color: ${ch.color}`}>&rarr;</span>
              </a>
            </li>
          ) : (
            <li class="flex items-center gap-5 sm:gap-6 py-5 sm:py-6 border-b border-[--color-warm-200]/40 px-3 sm:px-4 -mx-3 sm:-mx-4 opacity-30">
              <div class="shrink-0 flex items-center gap-3 sm:gap-4">
                <div class="w-3 h-3 rounded-full bg-[--color-warm-300] shrink-0"></div>
                <span class="font-[--font-display] text-2xl sm:text-3xl font-light text-[--color-warm-300] opacity-60 w-10 sm:w-12 tabular-nums text-right">
                  {String(ch.num).padStart(2, '0')}
                </span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-[--font-display] text-xl sm:text-2xl text-[--color-warm-300] leading-snug">{ch.lesson}</p>
                <p class="mt-1 text-sm text-[--color-warm-300]">{ch.name} &middot; coming soon</p>
              </div>
            </li>
          )
        ))}
      </ol>
    </section>

    <!-- Features — glass cards -->
    <section class="bg-gradient-to-b from-[--color-cream] to-[--color-warm-100]/50 border-t border-[--color-warm-200]">
      <div class="max-w-3xl mx-auto px-6 py-16 sm:py-20">
        <h2 class="font-[--font-display] text-2xl sm:text-3xl text-[--color-warm-800] mb-8 sm:mb-12 text-center">How every verse is presented</h2>
        <div class="grid sm:grid-cols-3 gap-4 sm:gap-5">
          <div class="feature-card rounded-2xl p-6 border border-[--color-warm-100]">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center text-white text-lg mb-4">8</div>
            <h3 class="font-[--font-display] text-lg text-[--color-warm-800] mb-2">Commentary Traditions</h3>
            <p class="text-sm text-[--color-warm-500] leading-relaxed">
              Advaita, Dvaita, Vishishtadvaita, Bhakti, Kashmir Shaivism, Shuddhadvaita, Karma Yoga, and Practical Vedanta — all synthesized.
            </p>
          </div>
          <div class="feature-card rounded-2xl p-6 border border-[--color-warm-100]">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center text-white text-lg mb-4">4</div>
            <h3 class="font-[--font-display] text-lg text-[--color-warm-800] mb-2">Life Pillars</h3>
            <p class="text-sm text-[--color-warm-500] leading-relaxed">
              Personal growth, career, health, and relationships — each verse becomes actionable wisdom with reflection questions.
            </p>
          </div>
          <div class="feature-card rounded-2xl p-6 border border-[--color-warm-100]">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500 to-rose-600 flex items-center justify-center text-white text-lg mb-4 font-[--font-devanagari]">अ</div>
            <h3 class="font-[--font-display] text-lg text-[--color-warm-800] mb-2">Sanskrit in 14 Days</h3>
            <p class="text-sm text-[--color-warm-500] leading-relaxed">
              <a href={`${import.meta.env.BASE_URL}learn-sanskrit/`} class="text-[--color-saffron] hover:text-[--color-warm-700] transition-colors underline underline-offset-2">Start the course</a> — learn to read Devanagari and understand IAST transliteration from scratch.
            </p>
          </div>
        </div>
      </div>
    </section>

  </main>

</BaseLayout>
