---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allShlokas = await getCollection('chapters');
const chaptersWithData = new Set(allShlokas.map((s) => s.data.chapter));

const chapterMeta = [
  { num: 1, sanskrit: 'अर्जुनविषादयोग', name: 'Arjuna\'s Dilemma', verses: 47 },
  { num: 2, sanskrit: 'सांख्ययोग', name: 'The Path of Knowledge', verses: 72 },
  { num: 3, sanskrit: 'कर्मयोग', name: 'The Path of Action', verses: 43 },
  { num: 4, sanskrit: 'ज्ञानकर्मसंन्यासयोग', name: 'Knowledge & Renunciation', verses: 42 },
  { num: 5, sanskrit: 'कर्मसंन्यासयोग', name: 'Renunciation of Action', verses: 29 },
  { num: 6, sanskrit: 'ध्यानयोग', name: 'The Path of Meditation', verses: 47 },
  { num: 7, sanskrit: 'ज्ञानविज्ञानयोग', name: 'Knowledge & Realization', verses: 30 },
  { num: 8, sanskrit: 'अक्षरब्रह्मयोग', name: 'The Imperishable Absolute', verses: 28 },
  { num: 9, sanskrit: 'राजविद्याराजगुह्ययोग', name: 'Royal Knowledge', verses: 34 },
  { num: 10, sanskrit: 'विभूतियोग', name: 'Divine Manifestations', verses: 42 },
  { num: 11, sanskrit: 'विश्वरूपदर्शनयोग', name: 'The Cosmic Vision', verses: 55 },
  { num: 12, sanskrit: 'भक्तियोग', name: 'The Path of Devotion', verses: 20 },
  { num: 13, sanskrit: 'क्षेत्रक्षेत्रज्ञविभागयोग', name: 'The Field & The Knower', verses: 35 },
  { num: 14, sanskrit: 'गुणत्रयविभागयोग', name: 'The Three Gunas', verses: 27 },
  { num: 15, sanskrit: 'पुरुषोत्तमयोग', name: 'The Supreme Person', verses: 20 },
  { num: 16, sanskrit: 'दैवासुरसम्पद्विभागयोग', name: 'Divine & Demonic Natures', verses: 24 },
  { num: 17, sanskrit: 'श्रद्धात्रयविभागयोग', name: 'Three Kinds of Faith', verses: 28 },
  { num: 18, sanskrit: 'मोक्षसंन्यासयोग', name: 'Liberation Through Surrender', verses: 78 },
];

const chapters = chapterMeta.map((ch) => ({
  ...ch,
  available: chaptersWithData.has(ch.num),
  loadedVerses: allShlokas.filter((s) => s.data.chapter === ch.num).length,
}));

const totalVerses = allShlokas.length;
const availableChapters = chapters.filter((ch) => ch.available).length;
---
<BaseLayout title="Home" description="The Bhagavad Gītā — 700 verses across 18 chapters, with 8 commentary traditions synthesized for modern life.">

  <main class="flex-1">

    <!-- Hero — minimal, text-forward -->
    <section class="max-w-2xl mx-auto px-6 pt-20 sm:pt-32 pb-16">
      <h1 class="font-[--font-display] text-4xl sm:text-5xl md:text-6xl font-light text-[--color-warm-900] leading-[1.1] tracking-tight animate-slide-up">
        The Bhagavad Gītā
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-[--color-warm-500] leading-relaxed max-w-xl animate-fade-in">
        700 verses of timeless wisdom — synthesized from eight commentary traditions, made actionable for modern life.
      </p>
      <div class="mt-6 flex flex-wrap gap-x-6 gap-y-1 text-sm text-[--color-warm-400] tracking-wide animate-fade-in">
        <span>18 chapters</span>
        <span>{totalVerses} verses</span>
        <span>8 traditions</span>
      </div>
    </section>

    <!-- Divider -->
    <div class="max-w-2xl mx-auto px-6">
      <div class="h-px bg-[--color-warm-200]"></div>
    </div>

    <!-- Chapters — numbered list like 37signals -->
    <section class="max-w-2xl mx-auto px-6 py-12 sm:py-16">
      <ol class="space-y-0">
        {chapters.map((ch) => (
          ch.available ? (
            <li>
              <a href={`${import.meta.env.BASE_URL}chapter/${ch.num}/`}
                 class="group flex items-baseline gap-5 py-4 sm:py-5 border-b border-[--color-warm-100] hover:border-[--color-saffron-light]/50 transition-colors duration-200">
                <span class="font-[--font-display] text-2xl sm:text-3xl font-light text-[--color-warm-300] group-hover:text-[--color-saffron] transition-colors duration-200 tabular-nums w-10 shrink-0 text-right">
                  {String(ch.num).padStart(2, '0')}
                </span>
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-baseline gap-x-3 gap-y-0.5">
                    <span class="font-[--font-display] text-xl sm:text-2xl text-[--color-warm-800] group-hover:text-[--color-saffron] transition-colors duration-200">
                      {ch.name}
                    </span>
                    <span class="font-[--font-devanagari] text-base text-[--color-warm-400]">
                      {ch.sanskrit}
                    </span>
                  </div>
                  <span class="text-xs text-[--color-warm-400] tracking-wide mt-0.5 block">
                    {ch.loadedVerses < ch.verses ? `${ch.loadedVerses} of ${ch.verses}` : ch.verses} verses
                  </span>
                </div>
                <span class="text-[--color-warm-300] group-hover:text-[--color-saffron] transition-colors duration-200 shrink-0 hidden sm:block">&rarr;</span>
              </a>
            </li>
          ) : (
            <li class="flex items-baseline gap-5 py-4 sm:py-5 border-b border-[--color-warm-100]/50 opacity-35">
              <span class="font-[--font-display] text-2xl sm:text-3xl font-light text-[--color-warm-300] tabular-nums w-10 shrink-0 text-right">
                {String(ch.num).padStart(2, '0')}
              </span>
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-0.5">
                  <span class="font-[--font-display] text-xl sm:text-2xl text-[--color-warm-300]">
                    {ch.name}
                  </span>
                  <span class="font-[--font-devanagari] text-base text-[--color-warm-300]">
                    {ch.sanskrit}
                  </span>
                </div>
                <span class="text-xs text-[--color-warm-300] tracking-wide mt-0.5 block">
                  {ch.verses} verses &middot; coming soon
                </span>
              </div>
            </li>
          )
        ))}
      </ol>
    </section>

    <!-- Divider -->
    <div class="max-w-2xl mx-auto px-6">
      <div class="h-px bg-[--color-warm-200]"></div>
    </div>

    <!-- Bottom sections — what this is -->
    <section class="max-w-2xl mx-auto px-6 py-12 sm:py-16">
      <div class="grid sm:grid-cols-3 gap-10 sm:gap-8">
        <div>
          <h3 class="font-[--font-display] text-lg text-[--color-warm-800] mb-2">Multi-tradition</h3>
          <p class="text-sm text-[--color-warm-500] leading-relaxed">
            Every verse synthesized from Advaita, Dvaita, Vishishtadvaita, Bhakti, Kashmir Shaivism, and more.
          </p>
        </div>
        <div>
          <h3 class="font-[--font-display] text-lg text-[--color-warm-800] mb-2">Actionable</h3>
          <p class="text-sm text-[--color-warm-500] leading-relaxed">
            Each verse mapped to personal growth, career, health, and relationships — with reflection questions.
          </p>
        </div>
        <div>
          <h3 class="font-[--font-display] text-lg text-[--color-warm-800] mb-2">Learn Sanskrit</h3>
          <p class="text-sm text-[--color-warm-500] leading-relaxed">
            A <a href={`${import.meta.env.BASE_URL}learn-sanskrit/`} class="text-[--color-saffron] hover:text-[--color-warm-700] transition-colors">14-day course</a> to read the original Devanagari script and understand IAST transliteration.
          </p>
        </div>
      </div>
    </section>

  </main>

</BaseLayout>
