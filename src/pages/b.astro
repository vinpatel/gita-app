---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allShlokas = await getCollection('chapters');
const chaptersWithData = new Set(allShlokas.map((s) => s.data.chapter));

const chapterMeta = [
  { num: 1, name: 'Arjuna\'s Dilemma', sanskrit: 'अर्जुनविषादयोग', verses: 47,
    gradient: 'from-slate-700 to-zinc-900',
    lesson: 'Inner conflict is the starting point of all growth' },
  { num: 2, name: 'The Path of Knowledge', sanskrit: 'सांख्ययोग', verses: 72,
    gradient: 'from-indigo-500 to-violet-700',
    lesson: 'Stop identifying with what changes' },
  { num: 3, name: 'The Path of Action', sanskrit: 'कर्मयोग', verses: 43,
    gradient: 'from-orange-500 to-red-600',
    lesson: 'Act without obsessing over results' },
  { num: 4, name: 'Knowledge & Renunciation', sanskrit: 'ज्ञानकर्मसंन्यासयोग', verses: 42,
    gradient: 'from-amber-500 to-orange-600',
    lesson: 'Knowledge burns karma like fire burns fuel' },
  { num: 5, name: 'Renunciation of Action', sanskrit: 'कर्मसंन्यासयोग', verses: 29,
    gradient: 'from-teal-500 to-green-700',
    lesson: 'Be free while fully engaged in the world' },
  { num: 6, name: 'The Path of Meditation', sanskrit: 'ध्यानयोग', verses: 47,
    gradient: 'from-violet-500 to-indigo-700',
    lesson: 'The mind is your greatest ally or worst enemy' },
  { num: 7, name: 'Knowledge & Realization', sanskrit: 'ज्ञानविज्ञानयोग', verses: 30,
    gradient: 'from-cyan-400 to-blue-600',
    lesson: 'One reality in infinite forms' },
  { num: 8, name: 'The Imperishable Absolute', sanskrit: 'अक्षरब्रह्मयोग', verses: 28,
    gradient: 'from-purple-500 to-pink-600',
    lesson: 'Your last thought shapes what comes next' },
  { num: 9, name: 'Royal Knowledge', sanskrit: 'राजविद्याराजगुह्ययोग', verses: 34,
    gradient: 'from-rose-500 to-red-600',
    lesson: 'A leaf offered with love reaches the divine' },
  { num: 10, name: 'Divine Manifestations', sanskrit: 'विभूतियोग', verses: 42,
    gradient: 'from-emerald-400 to-teal-600',
    lesson: 'Everything extraordinary is a glimpse of the infinite' },
  { num: 11, name: 'The Cosmic Vision', sanskrit: 'विश्वरूपदर्शनयोग', verses: 55,
    gradient: 'from-fuchsia-500 to-violet-800',
    lesson: 'Reality is vaster than the mind can hold' },
  { num: 12, name: 'The Path of Devotion', sanskrit: 'भक्तियोग', verses: 20,
    gradient: 'from-pink-400 to-rose-600',
    lesson: 'Love is the fastest path' },
  { num: 13, name: 'The Field & The Knower', sanskrit: 'क्षेत्रक्षेत्रज्ञविभागयोग', verses: 35,
    gradient: 'from-sky-400 to-indigo-600',
    lesson: 'You are the awareness, not the body' },
  { num: 14, name: 'The Three Gunas', sanskrit: 'गुणत्रयविभागयोग', verses: 27,
    gradient: 'from-lime-500 to-emerald-700',
    lesson: 'Clarity, passion, inertia — name them, then rise above' },
  { num: 15, name: 'The Supreme Person', sanskrit: 'पुरुषोत्तमयोग', verses: 20,
    gradient: 'from-yellow-400 to-orange-600',
    lesson: 'Cut the tree of attachment with detachment' },
  { num: 16, name: 'Divine & Demonic Natures', sanskrit: 'दैवासुरसम्पद्विभागयोग', verses: 24,
    gradient: 'from-red-500 to-rose-800',
    lesson: 'Desire, anger, greed — three gates to self-destruction' },
  { num: 17, name: 'Three Kinds of Faith', sanskrit: 'श्रद्धात्रयविभागयोग', verses: 28,
    gradient: 'from-blue-400 to-indigo-600',
    lesson: 'Your faith shapes what you eat, give, and become' },
  { num: 18, name: 'Liberation Through Surrender', sanskrit: 'मोक्षसंन्यासयोग', verses: 78,
    gradient: 'from-amber-500 to-red-700',
    lesson: 'Surrender everything — then act with full freedom' },
];

const chapters = chapterMeta.map((ch) => ({
  ...ch,
  available: chaptersWithData.has(ch.num),
  loadedVerses: allShlokas.filter((s) => s.data.chapter === ch.num).length,
}));

const totalVerses = allShlokas.length;
---
<BaseLayout title="Home" description="The Bhagavad Gītā — 18 life lessons from 700 verses.">

  <style>
    .hero-gradient {
      background: linear-gradient(135deg, #1e1a14 0%, #332D24 30%, #4A4035 60%, #C4832D 100%);
      background-size: 200% 200%;
      animation: gradient-shift 8s ease infinite;
    }
    @keyframes gradient-shift {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }
    .h-card {
      transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .h-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 20px 50px -15px rgba(0,0,0,0.3);
    }
    .h-card:hover .h-card-arrow {
      opacity: 1;
      transform: translateX(0);
    }
    .h-card:hover .h-card-num {
      opacity: 0.35;
    }
  </style>

  <main class="flex-1">

    <!-- Hero -->
    <section class="hero-gradient relative overflow-hidden">
      <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22 opacity=%22.15%22>%E0%A5%90</text></svg>'); background-size: 120px; background-repeat: repeat;"></div>
      <div class="relative max-w-5xl mx-auto px-6 pt-20 sm:pt-28 pb-16 sm:pb-24">
        <p class="font-[--font-devanagari] text-xl sm:text-2xl text-white/40 mb-4 animate-fade-in">श्रीमद्भगवद्गीता</p>
        <h1 class="font-[--font-display] text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-light text-white leading-[1.05] tracking-tight animate-slide-up">
          The Bhagavad Gītā
        </h1>
        <p class="mt-6 text-lg sm:text-xl md:text-2xl text-white/60 leading-relaxed max-w-2xl animate-fade-in">
          18 life lessons from a conversation between a warrior in crisis and his divine friend.
        </p>
        <div class="mt-8 flex flex-wrap gap-3 animate-fade-in">
          <span class="px-4 py-1.5 rounded-full bg-white/10 text-sm text-white/70">{totalVerses} verses</span>
          <span class="px-4 py-1.5 rounded-full bg-white/10 text-sm text-white/70">8 traditions</span>
          <span class="px-4 py-1.5 rounded-full bg-white/10 text-sm text-white/70">4 life pillars</span>
          <a href={`${import.meta.env.BASE_URL}learn-sanskrit/`} class="px-4 py-1.5 rounded-full bg-[--color-saffron]/80 text-sm text-white hover:bg-[--color-saffron] transition-colors">Learn Sanskrit</a>
        </div>
      </div>
    </section>

    <!-- Horizontal lesson cards -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-14 sm:py-20">
      {chapters.map((ch) => (
        ch.available ? (
          <a href={`${import.meta.env.BASE_URL}chapter/${ch.num}/`}
             class={`h-card block rounded-3xl bg-gradient-to-r ${ch.gradient} mb-4 sm:mb-5 overflow-hidden`}>
            <div class="flex items-center px-6 sm:px-10 md:px-12 py-7 sm:py-9 md:py-10 gap-5 sm:gap-8 md:gap-10">
              <!-- Number -->
              <span class="h-card-num font-[--font-display] text-5xl sm:text-7xl md:text-8xl font-light text-white/20 shrink-0 tabular-nums transition-opacity duration-200 w-16 sm:w-24 md:w-28 text-right">
                {String(ch.num).padStart(2, '0')}
              </span>
              <!-- Lesson + meta -->
              <div class="flex-1 min-w-0">
                <h2 class="font-[--font-display] text-2xl sm:text-3xl md:text-4xl lg:text-[2.75rem] text-white leading-[1.15] tracking-tight">
                  {ch.lesson}
                </h2>
                <p class="mt-2 sm:mt-3 text-sm sm:text-base text-white/45">
                  {ch.name} <span class="font-[--font-devanagari] ml-1">{ch.sanskrit}</span> <span class="ml-2 text-white/30">{ch.loadedVerses < ch.verses ? `${ch.loadedVerses}/${ch.verses}` : ch.verses} verses</span>
                </p>
              </div>
              <!-- Arrow -->
              <span class="h-card-arrow text-2xl sm:text-3xl text-white/60 shrink-0 opacity-0 -translate-x-3 transition-all duration-200 hidden sm:block">&rarr;</span>
            </div>
          </a>
        ) : (
          <div class="rounded-3xl bg-[--color-warm-200]/30 mb-4 sm:mb-5 opacity-30">
            <div class="flex items-center px-6 sm:px-10 md:px-12 py-7 sm:py-9 md:py-10 gap-5 sm:gap-8 md:gap-10">
              <span class="font-[--font-display] text-5xl sm:text-7xl md:text-8xl font-light text-[--color-warm-300]/30 shrink-0 tabular-nums w-16 sm:w-24 md:w-28 text-right">
                {String(ch.num).padStart(2, '0')}
              </span>
              <div class="flex-1 min-w-0">
                <h2 class="font-[--font-display] text-2xl sm:text-3xl md:text-4xl text-[--color-warm-300] leading-[1.15]">{ch.lesson}</h2>
                <p class="mt-2 text-sm text-[--color-warm-300]">{ch.name} &middot; coming soon</p>
              </div>
            </div>
          </div>
        )
      ))}
    </section>

    <!-- Features -->
    <section class="border-t border-[--color-warm-200] bg-[--color-warm-50]/50">
      <div class="max-w-5xl mx-auto px-6 py-16 sm:py-20">
        <div class="grid sm:grid-cols-3 gap-6 sm:gap-8">
          <div>
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center text-white text-lg mb-4">8</div>
            <h3 class="font-[--font-display] text-xl text-[--color-warm-800] mb-2">Commentary Traditions</h3>
            <p class="text-sm text-[--color-warm-500] leading-relaxed">
              Advaita, Dvaita, Vishishtadvaita, Bhakti, Kashmir Shaivism, Shuddhadvaita, Karma Yoga, and Practical Vedanta.
            </p>
          </div>
          <div>
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center text-white text-lg mb-4">4</div>
            <h3 class="font-[--font-display] text-xl text-[--color-warm-800] mb-2">Life Pillars</h3>
            <p class="text-sm text-[--color-warm-500] leading-relaxed">
              Personal growth, career, health, and relationships — each verse mapped with reflection questions.
            </p>
          </div>
          <div>
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500 to-rose-600 flex items-center justify-center text-white text-lg mb-4 font-[--font-devanagari]">अ</div>
            <h3 class="font-[--font-display] text-xl text-[--color-warm-800] mb-2">Sanskrit in 14 Days</h3>
            <p class="text-sm text-[--color-warm-500] leading-relaxed">
              <a href={`${import.meta.env.BASE_URL}learn-sanskrit/`} class="text-[--color-saffron] hover:text-[--color-warm-700] transition-colors underline underline-offset-2">Start the course</a> — read Devanagari and IAST from scratch.
            </p>
          </div>
        </div>
      </div>
    </section>

  </main>

</BaseLayout>
