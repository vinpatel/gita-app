---
import { getCollection } from 'astro:content';
import '../../styles/global.css';
import '@fontsource-variable/source-serif-4';
import '@fontsource-variable/inter';
import '@fontsource-variable/noto-sans-devanagari/wght.css';

const allShlokas = await getCollection('chapters');

type ChapterMeta = { sanskrit: string; name: string; verses: number; summary: string };

const chapterMeta: Record<number, ChapterMeta> = {
  1: { sanskrit: 'अर्जुनविषादयोग', name: "Arjuna's Dilemma", verses: 47, summary: 'On the battlefield of Kurukshetra, Arjuna sees his relatives, teachers, and friends on both sides. Overwhelmed by sorrow and moral confusion, he drops his bow and refuses to fight.' },
  2: { sanskrit: 'सांख्ययोग', name: 'The Path of Knowledge', verses: 72, summary: 'Krishna begins his teaching: the soul is eternal, the body is temporary. He introduces the core philosophy of the Gita, including detachment from results and the nature of a person of steady wisdom.' },
  3: { sanskrit: 'कर्मयोग', name: 'The Path of Action', verses: 43, summary: 'Krishna explains why action is superior to inaction. One must perform duties without attachment to results, maintaining equanimity in success and failure.' },
  4: { sanskrit: 'ज्ञानकर्मसंन्यासयोग', name: 'Knowledge & Renunciation', verses: 42, summary: 'Krishna reveals the ancient lineage of this teaching and explains how divine knowledge destroys the bondage of karma. He describes various forms of sacrifice and spiritual practice.' },
  5: { sanskrit: 'कर्मसंन्यासयोग', name: 'Renunciation of Action', verses: 29, summary: 'The paths of renunciation and selfless action are compared. Krishna teaches that true renunciation is internal — acting without ego and desire while remaining engaged in the world.' },
  6: { sanskrit: 'ध्यानयोग', name: 'The Path of Meditation', verses: 47, summary: 'Detailed instructions on meditation practice: posture, focus, diet, and lifestyle. Krishna addresses what happens to those who begin the spiritual path but do not complete it in one lifetime.' },
  7: { sanskrit: 'ज्ञानविज्ञानयोग', name: 'Knowledge & Realization', verses: 30, summary: 'Krishna reveals his divine nature — both the material and spiritual dimensions of reality. He explains why few truly know him and describes four types of seekers.' },
  8: { sanskrit: 'अक्षरब्रह्मयोग', name: 'The Imperishable Absolute', verses: 28, summary: "The nature of the imperishable Brahman, the process of death and rebirth, and how one's final thoughts determine the next destination. Krishna teaches the path beyond return." },
  9: { sanskrit: 'राजविद्याराजगुह्ययोग', name: 'Royal Knowledge', verses: 34, summary: 'The most confidential knowledge: Krishna pervades all creation yet remains transcendent. Simple devotion — offering a leaf, flower, or water with love — reaches the divine directly.' },
  10: { sanskrit: 'विभूतियोग', name: 'Divine Manifestations', verses: 42, summary: 'Krishna describes his divine manifestations throughout creation — the best, the most powerful, the most beautiful in every category. Everything extraordinary is a spark of his splendor.' },
  11: { sanskrit: 'विश्वरूपदर्शनयोग', name: 'The Cosmic Vision', verses: 55, summary: "Arjuna is granted divine vision to behold Krishna's universal form — infinite, all-encompassing, terrifying and beautiful. He sees all of creation, destruction, and time itself." },
  12: { sanskrit: 'भक्तियोग', name: 'The Path of Devotion', verses: 20, summary: 'Krishna declares devotion as the supreme path and describes the qualities of his dearest devotees: compassionate, humble, content, forgiving, and unwavering in faith.' },
  13: { sanskrit: 'क्षेत्रक्षेत्रज्ञविभागयोग', name: 'The Field & The Knower', verses: 35, summary: 'The distinction between the body (the field) and the soul (the knower of the field). Krishna explains the elements of material nature and the qualities that lead to true knowledge.' },
  14: { sanskrit: 'गुणत्रयविभागयोग', name: 'The Three Gunas', verses: 27, summary: 'The three qualities of material nature — sattva (goodness), rajas (passion), and tamas (ignorance) — and how they bind the soul. Krishna teaches how to transcend all three.' },
  15: { sanskrit: 'पुरुषोत्तमयोग', name: 'The Supreme Person', verses: 20, summary: 'The metaphor of the cosmic banyan tree, rooted above and branching below. Krishna reveals himself as the Supreme Person, beyond both the perishable and imperishable.' },
  16: { sanskrit: 'दैवासुरसम्पद्विभागयोग', name: 'Divine & Demonic Natures', verses: 24, summary: 'Two types of human tendencies: divine qualities (fearlessness, purity, compassion) and demonic qualities (arrogance, anger, ignorance). Krishna urges cultivation of divine nature.' },
  17: { sanskrit: 'श्रद्धात्रयविभागयोग', name: 'Three Kinds of Faith', verses: 28, summary: 'Faith itself comes in three types, shaped by the gunas. Krishna examines how food, worship, austerity, and charity differ based on whether they arise from goodness, passion, or ignorance.' },
  18: { sanskrit: 'मोक्षसंन्यासयोग', name: 'Liberation Through Surrender', verses: 78, summary: "The grand conclusion: Krishna summarizes all paths, reveals his most confidential teaching, and gives Arjuna the freedom to choose. Arjuna's doubt is destroyed; he is ready to act." },
};

const byChapter = Array.from({ length: 18 }, (_, i) => {
  const num = i + 1;
  const verses = allShlokas
    .filter((s) => s.data.chapter === num)
    .sort((a, b) => a.data.verse - b.data.verse);
  return { num, ...chapterMeta[num], loaded: verses };
});

const totalLoaded = byChapter.reduce((sum, c) => sum + c.loaded.length, 0);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="The Bhagavad Gītā — Book edition. All 18 chapters with Sanskrit, IAST, translation, and synthesis. Free download." />
    <title>The Bhagavad Gītā — Book Edition | bhagavad.net</title>
    <style is:global>
      :root {
        --book-text: #1c1917;
        --book-muted: #57534e;
        --book-faint: #a8a29e;
        --book-accent: #C4832D;
        --book-rule: #e7e5e4;
      }

      body.book-body {
        font-family: 'Source Serif 4 Variable', Georgia, serif;
        color: var(--book-text);
        background: #ffffff;
        line-height: 1.7;
        font-size: 11.5pt;
        max-width: none;
        margin: 0;
      }

      .book-shell {
        max-width: 720px;
        margin: 0 auto;
        padding: 4rem 2rem 6rem;
      }

      .book-toolbar {
        position: sticky;
        top: 0;
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--book-rule);
        padding: 0.85rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: 'Inter Variable', system-ui, sans-serif;
        font-size: 0.85rem;
        z-index: 10;
      }
      .book-toolbar a {
        color: var(--book-muted);
        text-decoration: none;
      }
      .book-toolbar a:hover { color: var(--book-text); }
      .book-toolbar .download {
        background: var(--book-text);
        color: #fff;
        padding: 0.5rem 1rem;
        border-radius: 999px;
        font-weight: 600;
      }
      .book-toolbar .download:hover { color: #fff; background: var(--book-accent); }

      .cover {
        text-align: center;
        padding: 6rem 0 5rem;
        border-bottom: 1px solid var(--book-rule);
        margin-bottom: 4rem;
      }
      .cover .devanagari {
        font-family: 'Noto Sans Devanagari Variable', sans-serif;
        font-size: 2.5rem;
        color: var(--book-accent);
        margin-bottom: 1.5rem;
      }
      .cover h1 {
        font-family: 'Inter Variable', system-ui, sans-serif;
        font-size: 3.4rem;
        font-weight: 900;
        line-height: 1.05;
        margin: 0 0 1rem;
        letter-spacing: -0.02em;
      }
      .cover .subtitle {
        font-family: 'Inter Variable', system-ui, sans-serif;
        font-size: 1.1rem;
        color: var(--book-muted);
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 0.18em;
      }
      .cover .meta {
        margin-top: 3rem;
        color: var(--book-faint);
        font-size: 0.9rem;
        font-family: 'Inter Variable', system-ui, sans-serif;
      }

      .toc {
        margin-bottom: 5rem;
      }
      .toc h2 {
        font-family: 'Inter Variable', system-ui, sans-serif;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.25em;
        color: var(--book-muted);
        margin: 0 0 2rem;
        font-weight: 700;
      }
      .toc ol {
        list-style: none;
        padding: 0;
        margin: 0;
        counter-reset: ch;
      }
      .toc li {
        counter-increment: ch;
        display: flex;
        align-items: baseline;
        gap: 1rem;
        padding: 0.65rem 0;
        border-bottom: 1px dotted var(--book-rule);
      }
      .toc li::before {
        content: counter(ch, decimal-leading-zero);
        font-family: 'Inter Variable', system-ui, sans-serif;
        font-weight: 700;
        color: var(--book-accent);
        min-width: 2.5rem;
      }
      .toc li a {
        color: var(--book-text);
        text-decoration: none;
        font-weight: 600;
        flex: 1;
      }
      .toc li .ch-sanskrit {
        font-family: 'Noto Sans Devanagari Variable', sans-serif;
        color: var(--book-muted);
        font-size: 0.95em;
      }

      .chapter {
        page-break-before: always;
        break-before: page;
        margin-bottom: 5rem;
      }
      .chapter-head {
        text-align: center;
        padding: 3rem 0 2.5rem;
        border-bottom: 2px solid var(--book-text);
        margin-bottom: 3rem;
      }
      .chapter-head .ch-num {
        font-family: 'Inter Variable', system-ui, sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        font-size: 0.8rem;
        color: var(--book-faint);
        font-weight: 700;
      }
      .chapter-head .ch-sanskrit {
        font-family: 'Noto Sans Devanagari Variable', sans-serif;
        font-size: 1.6rem;
        color: var(--book-accent);
        margin: 0.6rem 0 0.4rem;
      }
      .chapter-head h2 {
        font-family: 'Inter Variable', system-ui, sans-serif;
        font-size: 2.4rem;
        font-weight: 900;
        line-height: 1.05;
        margin: 0 0 1rem;
        letter-spacing: -0.015em;
      }
      .chapter-head .summary {
        max-width: 32rem;
        margin: 1.2rem auto 0;
        color: var(--book-muted);
        font-style: italic;
        font-size: 1rem;
      }

      .verse {
        page-break-inside: avoid;
        break-inside: avoid;
        margin-bottom: 2.5rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--book-rule);
      }
      .verse:last-child { border-bottom: none; }
      .verse h3 {
        font-family: 'Inter Variable', system-ui, sans-serif;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--book-accent);
        margin: 0 0 1rem;
        font-weight: 700;
      }
      .verse .sanskrit {
        font-family: 'Noto Sans Devanagari Variable', sans-serif;
        font-size: 1.2rem;
        line-height: 1.95;
        margin: 0 0 0.4rem;
        white-space: pre-line;
        color: var(--book-text);
      }
      .verse .iast {
        font-style: italic;
        color: var(--book-muted);
        margin: 0 0 1.4rem;
        white-space: pre-line;
        font-size: 0.95rem;
      }
      .verse .explanation {
        margin: 0 0 1.2rem;
      }
      .verse .synthesis {
        background: #faf7f2;
        border-left: 3px solid var(--book-accent);
        padding: 1rem 1.2rem;
        margin: 1.2rem 0 0;
        font-size: 0.95rem;
        color: var(--book-muted);
      }
      .verse .synthesis strong {
        font-family: 'Inter Variable', system-ui, sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.7rem;
        color: var(--book-accent);
        display: block;
        margin-bottom: 0.4rem;
      }

      .end-page {
        page-break-before: always;
        break-before: page;
        text-align: center;
        padding: 4rem 0 2rem;
        color: var(--book-muted);
      }
      .end-page p { margin: 0.4rem 0; }
      .end-page .devanagari {
        font-family: 'Noto Sans Devanagari Variable', sans-serif;
        font-size: 1.4rem;
        color: var(--book-accent);
        margin-bottom: 1.2rem;
      }

      @media print {
        @page {
          size: A4;
          margin: 18mm 15mm 18mm 15mm;
        }
        .book-toolbar { display: none; }
        .book-shell { max-width: none; padding: 0; }
        body.book-body { font-size: 10.5pt; }
        .cover { padding: 4rem 0 3rem; page-break-after: always; }
        .toc { page-break-after: always; }
        .verse .synthesis { background: transparent; }
        a { color: inherit; text-decoration: none; }
      }
    </style>
  </head>
  <body class="book-body">
    <div class="book-toolbar">
      <a href={`${import.meta.env.BASE_URL}`}>&larr; bhagavad.net</a>
      <a class="download" href={`${import.meta.env.BASE_URL}downloads/gita-en.pdf`}>Download PDF</a>
    </div>

    <div class="book-shell">
      <header class="cover">
        <div class="devanagari">श्रीमद्भगवद्गीता</div>
        <h1>The Bhagavad Gītā</h1>
        <p class="subtitle">Multi-Tradition Synthesis</p>
        <p class="meta">{totalLoaded} verses · 18 chapters · bhagavad.net</p>
      </header>

      <nav class="toc" aria-label="Table of contents">
        <h2>Contents</h2>
        <ol>
          {byChapter.map((c) => (
            <li>
              <a href={`#chapter-${c.num}`}>{c.name}</a>
              <span class="ch-sanskrit">{c.sanskrit}</span>
            </li>
          ))}
        </ol>
      </nav>

      {byChapter.map((c) => (
        <section id={`chapter-${c.num}`} class="chapter">
          <header class="chapter-head">
            <p class="ch-num">Chapter {c.num} of 18</p>
            <p class="ch-sanskrit">{c.sanskrit}</p>
            <h2>{c.name}</h2>
            <p class="summary">{c.summary}</p>
          </header>

          {c.loaded.length === 0 && (
            <p style="text-align:center;color:var(--book-faint);font-style:italic;">Verses for this chapter are coming soon.</p>
          )}

          {c.loaded.map((v) => (
            <article class="verse">
              <h3>Verse {c.num}.{v.data.verse}</h3>
              <p class="sanskrit">{v.data.sanskrit}</p>
              <p class="iast">{v.data.iast}</p>
              <p class="explanation">{v.data.explanation}</p>
              <div class="synthesis">
                <strong>Synthesis</strong>
                {v.data.synthesis}
              </div>
            </article>
          ))}
        </section>
      ))}

      <div class="end-page">
        <div class="devanagari">ॐ शान्तिः शान्तिः शान्तिः</div>
        <p>The Bhagavad Gītā · Book Edition</p>
        <p>bhagavad.net · Open source · Multi-tradition synthesis</p>
      </div>
    </div>
  </body>
</html>
