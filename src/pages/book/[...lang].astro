---
import '../../styles/global.css';
import '@fontsource-variable/source-serif-4';
import '@fontsource-variable/inter';
import '@fontsource-variable/noto-sans-devanagari/wght.css';

import {
  DEFAULT_LOCALE,
  HTML_LANG,
  LOCALE_LABELS,
  discoverLocales,
  loadChapterMeta,
  loadVerses,
} from '../../lib/book-data';

export async function getStaticPaths() {
  const locales = await discoverLocales();
  return locales.map((loc) => ({
    params: { lang: loc === DEFAULT_LOCALE ? undefined : loc },
    props: { locale: loc },
  }));
}

const { locale } = Astro.props as { locale: string };

const meta = await loadChapterMeta(locale);
const allLocales = await discoverLocales();

const byChapter = await Promise.all(
  Array.from({ length: 18 }, async (_, i) => {
    const num = i + 1;
    const { verses, translated } = await loadVerses(num, locale);
    return { num, ...meta[num], loaded: verses, translated };
  })
);

const totalLoaded = byChapter.reduce((sum, c) => sum + c.loaded.length, 0);
const isDefault = locale === DEFAULT_LOCALE;
const baseHref = `${import.meta.env.BASE_URL}book/`;
const otherLocales = allLocales.filter((l) => l !== locale);
const pdfHref = `${import.meta.env.BASE_URL}downloads/gita-${locale}.pdf`;
const htmlLang = HTML_LANG[locale] ?? 'en';

const STRINGS: Record<string, Record<string, string>> = {
  en: {
    title: 'The Bhagavad Gītā',
    subtitle: 'Multi-Tradition Synthesis',
    contents: 'Contents',
    chapter: 'Chapter',
    of: 'of',
    verse: 'Verse',
    synthesis: 'Synthesis',
    download: 'Download PDF',
    backToSite: '← bhagavad.net',
    versesAvailable: 'verses · 18 chapters · bhagavad.net',
    comingSoon: 'Verses for this chapter are coming soon.',
    closing: 'The Bhagavad Gītā · Book Edition',
    closingTagline: 'bhagavad.net · Open source · Multi-tradition synthesis',
    fallbackBanner: 'Translation in progress for this language. Showing English text where translation is not yet available.',
  },
  hi: {
    title: 'श्रीमद्भगवद्गीता',
    subtitle: 'बहु-परम्परा संश्लेषण',
    contents: 'विषय-सूची',
    chapter: 'अध्याय',
    of: 'का',
    verse: 'श्लोक',
    synthesis: 'संश्लेषण',
    download: 'पीडीएफ डाउनलोड करें',
    backToSite: '← bhagavad.net',
    versesAvailable: 'श्लोक · 18 अध्याय · bhagavad.net',
    comingSoon: 'इस अध्याय के श्लोक शीघ्र ही उपलब्ध होंगे।',
    closing: 'श्रीमद्भगवद्गीता · पुस्तक संस्करण',
    closingTagline: 'bhagavad.net · ओपन सोर्स · बहु-परम्परा संश्लेषण',
    fallbackBanner: 'इस भाषा के लिए अनुवाद कार्य जारी है। जहाँ अनुवाद उपलब्ध नहीं है वहाँ अंग्रेज़ी पाठ दिखाया गया है।',
  },
};

const t = STRINGS[locale] ?? STRINGS.en;
const someUntranslated = !isDefault && byChapter.some((c) => !c.translated);
const goatcounter = import.meta.env.PUBLIC_GOATCOUNTER_CODE;
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`The Bhagavad Gītā — Book edition (${LOCALE_LABELS[locale]?.english ?? locale}). All 18 chapters with Sanskrit, IAST, translation, and synthesis. Free download.`} />
    <title>{t.title} — Book Edition | bhagavad.net</title>
    {goatcounter && (
      <script
        is:inline
        async
        data-goatcounter={`https://${goatcounter}.goatcounter.com/count`}
        src="//gc.zgo.at/count.js"
      ></script>
    )}
    <style is:global>
      :root {
        --book-text: #1c1917;
        --book-muted: #57534e;
        --book-faint: #a8a29e;
        --book-accent: #C4832D;
        --book-rule: #e7e5e4;
      }

      body.book-body {
        font-family: 'Source Serif 4 Variable', Georgia, serif;
        color: var(--book-text);
        background: #ffffff;
        line-height: 1.7;
        font-size: 11.5pt;
        max-width: none;
        margin: 0;
      }

      .book-shell {
        max-width: 720px;
        margin: 0 auto;
        padding: 4rem 2rem 6rem;
      }

      .book-toolbar {
        position: sticky;
        top: 0;
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--book-rule);
        padding: 0.85rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        font-family: 'Inter Variable', system-ui, sans-serif;
        font-size: 0.85rem;
        z-index: 10;
        flex-wrap: wrap;
      }
      .book-toolbar a {
        color: var(--book-muted);
        text-decoration: none;
      }
      .book-toolbar a:hover { color: var(--book-text); }
      .book-toolbar .lang-switch {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
      }
      .book-toolbar .lang-switch a {
        padding: 0.25rem 0.6rem;
        border: 1px solid var(--book-rule);
        border-radius: 999px;
        font-size: 0.78rem;
      }
      .book-toolbar .lang-switch a.current {
        background: var(--book-text);
        color: #fff;
        border-color: var(--book-text);
      }
      .book-toolbar .lang-switch a:hover {
        border-color: var(--book-text);
      }
      .book-toolbar .download {
        background: var(--book-text);
        color: #fff;
        padding: 0.5rem 1rem;
        border-radius: 999px;
        font-weight: 600;
      }
      .book-toolbar .download:hover { color: #fff; background: var(--book-accent); }

      .fallback-banner {
        background: #fef3c7;
        border-bottom: 1px solid #fde68a;
        color: #92400e;
        padding: 0.6rem 2rem;
        text-align: center;
        font-family: 'Inter Variable', system-ui, sans-serif;
        font-size: 0.8rem;
      }

      .cover {
        text-align: center;
        padding: 6rem 0 5rem;
        border-bottom: 1px solid var(--book-rule);
        margin-bottom: 4rem;
      }
      .cover .devanagari {
        font-family: 'Noto Sans Devanagari Variable', sans-serif;
        font-size: 2.5rem;
        color: var(--book-accent);
        margin-bottom: 1.5rem;
      }
      .cover h1 {
        font-family: 'Inter Variable', system-ui, sans-serif;
        font-size: 3.4rem;
        font-weight: 900;
        line-height: 1.05;
        margin: 0 0 1rem;
        letter-spacing: -0.02em;
      }
      .cover h1.devanagari-title {
        font-family: 'Noto Sans Devanagari Variable', sans-serif;
        font-size: 3rem;
        font-weight: 700;
      }
      .cover .subtitle {
        font-family: 'Inter Variable', system-ui, sans-serif;
        font-size: 1.1rem;
        color: var(--book-muted);
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 0.18em;
      }
      .cover .meta {
        margin-top: 3rem;
        color: var(--book-faint);
        font-size: 0.9rem;
        font-family: 'Inter Variable', system-ui, sans-serif;
      }

      .toc {
        margin-bottom: 5rem;
      }
      .toc h2 {
        font-family: 'Inter Variable', system-ui, sans-serif;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.25em;
        color: var(--book-muted);
        margin: 0 0 2rem;
        font-weight: 700;
      }
      .toc ol {
        list-style: none;
        padding: 0;
        margin: 0;
        counter-reset: ch;
      }
      .toc li {
        counter-increment: ch;
        display: flex;
        align-items: baseline;
        gap: 1rem;
        padding: 0.65rem 0;
        border-bottom: 1px dotted var(--book-rule);
      }
      .toc li::before {
        content: counter(ch, decimal-leading-zero);
        font-family: 'Inter Variable', system-ui, sans-serif;
        font-weight: 700;
        color: var(--book-accent);
        min-width: 2.5rem;
      }
      .toc li a {
        color: var(--book-text);
        text-decoration: none;
        font-weight: 600;
        flex: 1;
      }
      .toc li .ch-sanskrit {
        font-family: 'Noto Sans Devanagari Variable', sans-serif;
        color: var(--book-muted);
        font-size: 0.95em;
      }

      .chapter {
        page-break-before: always;
        break-before: page;
        margin-bottom: 5rem;
      }
      .chapter-head {
        text-align: center;
        padding: 3rem 0 2.5rem;
        border-bottom: 2px solid var(--book-text);
        margin-bottom: 3rem;
      }
      .chapter-head .ch-num {
        font-family: 'Inter Variable', system-ui, sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        font-size: 0.8rem;
        color: var(--book-faint);
        font-weight: 700;
      }
      .chapter-head .ch-sanskrit {
        font-family: 'Noto Sans Devanagari Variable', sans-serif;
        font-size: 1.6rem;
        color: var(--book-accent);
        margin: 0.6rem 0 0.4rem;
      }
      .chapter-head h2 {
        font-family: 'Inter Variable', system-ui, sans-serif;
        font-size: 2.4rem;
        font-weight: 900;
        line-height: 1.05;
        margin: 0 0 1rem;
        letter-spacing: -0.015em;
      }
      .chapter-head h2.devanagari-h2 {
        font-family: 'Noto Sans Devanagari Variable', sans-serif;
        font-weight: 700;
      }
      .chapter-head .summary {
        max-width: 32rem;
        margin: 1.2rem auto 0;
        color: var(--book-muted);
        font-style: italic;
        font-size: 1rem;
      }

      .verse {
        page-break-inside: avoid;
        break-inside: avoid;
        margin-bottom: 2.5rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--book-rule);
      }
      .verse:last-child { border-bottom: none; }
      .verse h3 {
        font-family: 'Inter Variable', system-ui, sans-serif;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--book-accent);
        margin: 0 0 1rem;
        font-weight: 700;
      }
      .verse .sanskrit {
        font-family: 'Noto Sans Devanagari Variable', sans-serif;
        font-size: 1.2rem;
        line-height: 1.95;
        margin: 0 0 0.4rem;
        white-space: pre-line;
        color: var(--book-text);
      }
      .verse .iast {
        font-style: italic;
        color: var(--book-muted);
        margin: 0 0 1.4rem;
        white-space: pre-line;
        font-size: 0.95rem;
      }
      .verse .explanation {
        margin: 0 0 1.2rem;
      }
      .verse .synthesis {
        background: #faf7f2;
        border-left: 3px solid var(--book-accent);
        padding: 1rem 1.2rem;
        margin: 1.2rem 0 0;
        font-size: 0.95rem;
        color: var(--book-muted);
      }
      .verse .synthesis strong {
        font-family: 'Inter Variable', system-ui, sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.7rem;
        color: var(--book-accent);
        display: block;
        margin-bottom: 0.4rem;
      }

      .end-page {
        page-break-before: always;
        break-before: page;
        text-align: center;
        padding: 4rem 0 2rem;
        color: var(--book-muted);
      }
      .end-page p { margin: 0.4rem 0; }
      .end-page .devanagari {
        font-family: 'Noto Sans Devanagari Variable', sans-serif;
        font-size: 1.4rem;
        color: var(--book-accent);
        margin-bottom: 1.2rem;
      }

      @media print {
        @page {
          size: A4;
          margin: 18mm 15mm 18mm 15mm;
        }
        .book-toolbar, .fallback-banner { display: none; }
        .book-shell { max-width: none; padding: 0; }
        body.book-body { font-size: 10.5pt; }
        .cover { padding: 4rem 0 3rem; page-break-after: always; }
        .toc { page-break-after: always; }
        .verse .synthesis { background: transparent; }
        a { color: inherit; text-decoration: none; }
      }
    </style>
  </head>
  <body class="book-body">
    <div class="book-toolbar">
      <a href={`${import.meta.env.BASE_URL}`}>{t.backToSite}</a>
      <div class="lang-switch" aria-label="Language">
        <a href={baseHref} class={isDefault ? 'current' : ''}>EN</a>
        {otherLocales
          .filter((l) => l !== DEFAULT_LOCALE)
          .map((l) => (
            <a
              href={`${baseHref}${l}/`}
              class={l === locale ? 'current' : ''}
              aria-label={LOCALE_LABELS[l]?.english ?? l}
            >
              {LOCALE_LABELS[l]?.native ?? l.toUpperCase()}
            </a>
          ))}
      </div>
      <a
        class="download"
        href={pdfHref}
        data-goatcounter-click={`pdf-download-${locale}`}
        data-goatcounter-title={`Download PDF (${LOCALE_LABELS[locale]?.english ?? locale})`}
      >{t.download}</a>
    </div>

    {someUntranslated && (
      <div class="fallback-banner">{t.fallbackBanner}</div>
    )}

    <div class="book-shell">
      <header class="cover">
        <div class="devanagari">श्रीमद्भगवद्गीता</div>
        {locale === 'hi' ? (
          <h1 class="devanagari-title">{t.title}</h1>
        ) : (
          <h1>{t.title}</h1>
        )}
        <p class="subtitle">{t.subtitle}</p>
        <p class="meta">{totalLoaded} {t.versesAvailable}</p>
      </header>

      <nav class="toc" aria-label={t.contents}>
        <h2>{t.contents}</h2>
        <ol>
          {byChapter.map((c) => (
            <li>
              <a href={`#chapter-${c.num}`}>{c.name}</a>
              <span class="ch-sanskrit">{c.sanskrit}</span>
            </li>
          ))}
        </ol>
      </nav>

      {byChapter.map((c) => (
        <section id={`chapter-${c.num}`} class="chapter">
          <header class="chapter-head">
            <p class="ch-num">{t.chapter} {c.num} {t.of} 18</p>
            <p class="ch-sanskrit">{c.sanskrit}</p>
            {locale === 'hi' ? (
              <h2 class="devanagari-h2">{c.name}</h2>
            ) : (
              <h2>{c.name}</h2>
            )}
            <p class="summary">{c.summary}</p>
          </header>

          {c.loaded.length === 0 && (
            <p style="text-align:center;color:var(--book-faint);font-style:italic;">{t.comingSoon}</p>
          )}

          {c.loaded.map((v) => (
            <article class="verse">
              <h3>{t.verse} {c.num}.{v.verse}</h3>
              <p class="sanskrit">{v.sanskrit}</p>
              <p class="iast">{v.iast}</p>
              <p class="explanation">{v.explanation}</p>
              <div class="synthesis">
                <strong>{t.synthesis}</strong>
                {v.synthesis}
              </div>
            </article>
          ))}
        </section>
      ))}

      <div class="end-page">
        <div class="devanagari">ॐ शान्तिः शान्तिः शान्तिः</div>
        <p>{t.closing}</p>
        <p>{t.closingTagline}</p>
      </div>
    </div>
  </body>
</html>
