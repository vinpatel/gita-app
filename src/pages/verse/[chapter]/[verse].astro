---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import CommentaryTabs from '@components/islands/CommentaryTabs.tsx';
import ApplicationCards from '@components/islands/ApplicationCards.tsx';

const allShlokas = await getCollection('chapters');

export async function getStaticPaths() {
  const allShlokas = await getCollection('chapters');
  return allShlokas.map((s) => ({
    params: { chapter: String(s.data.chapter), verse: String(s.data.verse) },
  }));
}

const chapterNum = Number(Astro.params.chapter);
const verseNum = Number(Astro.params.verse);
const shloka = allShlokas.find(
  (s) => s.data.chapter === chapterNum && s.data.verse === verseNum
);

if (!shloka) return Astro.redirect('/');

const d = shloka.data;

const chapterShlokas = allShlokas
  .filter((s) => s.data.chapter === chapterNum)
  .sort((a, b) => a.data.verse - b.data.verse);
const idx = chapterShlokas.findIndex((s) => s.data.verse === verseNum);
const prev = idx > 0 ? chapterShlokas[idx - 1] : null;
const next = idx < chapterShlokas.length - 1 ? chapterShlokas[idx + 1] : null;

const chapterNames: Record<number, string> = {
  1: "Arjuna's Dilemma", 2: 'The Path of Knowledge', 3: 'The Path of Action',
  4: 'Knowledge & Renunciation', 5: 'Renunciation of Action', 6: 'The Path of Meditation',
  7: 'Knowledge & Realization', 8: 'The Imperishable Absolute', 9: 'Royal Knowledge',
  10: 'Divine Manifestations', 11: 'The Cosmic Vision', 12: 'The Path of Devotion',
  13: 'The Field & The Knower', 14: 'The Three Gunas', 15: 'The Supreme Person',
  16: 'Divine & Demonic Natures', 17: 'Three Kinds of Faith', 18: 'Liberation Through Surrender',
};

const sanskritLines = d.sanskrit.split('\n').filter(Boolean);
const iastLines = d.iast.split('\n').filter(Boolean);

const chapterName = chapterNames[chapterNum] ?? '';
const seoTitle = `Bhagavad Gita ${chapterNum}.${verseNum} — Meaning, Translation & Commentary | ${chapterName}`;
// Description: short, ~155 chars, leading with the topic + key teaching
const explanationSnippet = d.explanation.length > 140
  ? d.explanation.slice(0, 137).replace(/\s+\S*$/, '') + '…'
  : d.explanation;
const seoDescription = `Bhagavad Gītā Verse ${chapterNum}.${verseNum} — ${explanationSnippet}`;

const verseJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      'headline': `Bhagavad Gita ${chapterNum}.${verseNum}: ${chapterName}`,
      'description': explanationSnippet,
      'inLanguage': 'en',
      'isPartOf': { '@id': 'https://bhagavad.net/#book' },
      'about': {
        '@type': 'Quotation',
        'text': d.iast,
        'inLanguage': 'sa',
      },
      'url': `https://bhagavad.net/verse/${chapterNum}/${verseNum}/`,
      'keywords': d.themes.join(', '),
      'author': { '@type': 'Organization', 'name': 'bhagavad.net' },
      'publisher': {
        '@type': 'Organization',
        'name': 'bhagavad.net',
        'url': 'https://bhagavad.net/',
      },
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://bhagavad.net/' },
        { '@type': 'ListItem', 'position': 2, 'name': `Chapter ${chapterNum}: ${chapterName}`, 'item': `https://bhagavad.net/chapter/${chapterNum}/` },
        { '@type': 'ListItem', 'position': 3, 'name': `Verse ${chapterNum}.${verseNum}`, 'item': `https://bhagavad.net/verse/${chapterNum}/${verseNum}/` },
      ],
    },
  ],
};
---
<BaseLayout title={seoTitle} description={seoDescription} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(verseJsonLd)} />
  </Fragment>

  <!-- Verse header — chapter color background -->
  <header class={`chapter-${chapterNum}`}>
    <div class="px-6 py-10 sm:py-14" style={`background-color: var(--ch-bg); color: var(--ch-text);`}>
      <nav class="max-w-3xl mx-auto flex items-center justify-between mb-8">
        <a href={`${import.meta.env.BASE_URL}chapter/${chapterNum}/`}
           class="text-sm opacity-70 hover:opacity-100 transition-opacity">
          &larr; Chapter {chapterNum}
        </a>
        <div class="flex gap-4">
          {prev && (
            <a href={`${import.meta.env.BASE_URL}verse/${chapterNum}/${prev.data.verse}/`}
               class="text-sm opacity-70 hover:opacity-100 transition-opacity">
              &larr; Prev
            </a>
          )}
          {next && (
            <a href={`${import.meta.env.BASE_URL}verse/${chapterNum}/${next.data.verse}/`}
               class="text-sm opacity-70 hover:opacity-100 transition-opacity">
              Next &rarr;
            </a>
          )}
        </div>
      </nav>

      <div class="max-w-3xl mx-auto text-center">
        <p class="text-sm uppercase tracking-[0.3em] opacity-60 mb-6">
          {chapterNames[chapterNum]} &middot; Verse {verseNum}
        </p>

        <div class="space-y-1">
          {sanskritLines.map((line) => (
            <p class="font-[--font-devanagari] text-xl sm:text-2xl leading-[1.9]" style="font-size: 110%;">
              {line}
            </p>
          ))}
        </div>

        <div class="my-6 mx-auto w-16 h-px opacity-30 bg-current"></div>

        <div class="space-y-0.5">
          {iastLines.map((line) => (
            <p class="text-sm sm:text-base italic opacity-70 leading-[1.8] tracking-wide">
              {line}
            </p>
          ))}
        </div>
      </div>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-6 py-12 pb-24 flex-1">

    <!-- Explanation -->
    <section class="mb-10">
      <p class="text-base sm:text-lg text-[--color-text] leading-[1.9]">
        {d.explanation}
      </p>
    </section>

    <!-- Themes -->
    <div class="flex flex-wrap gap-2 mb-12">
      {d.themes.map((t) => (
        <span class="rounded-full border border-[--color-border] px-3.5 py-1 text-xs text-[--color-text-3] tracking-wide">
          {t}
        </span>
      ))}
    </div>

    <!-- Synthesis -->
    <section class="mb-12">
      <h2 class="font-[--font-display] text-2xl sm:text-3xl font-bold text-[--color-text] mb-5">Synthesis</h2>
      <div class="rounded-xl border border-[--color-border] p-6 sm:p-8">
        <p class="text-base text-[--color-text-2] leading-[1.85]">{d.synthesis}</p>
      </div>
    </section>

    <!-- Commentaries -->
    <section class="mb-12">
      <h2 class="font-[--font-display] text-2xl sm:text-3xl font-bold text-[--color-text] mb-5">
        Commentaries
        <span class="text-sm font-normal text-[--color-text-3] ml-2">{d.commentaries.length} traditions</span>
      </h2>
      <CommentaryTabs client:visible commentaries={d.commentaries} />
    </section>

    <!-- Life Applications -->
    <section class="mb-12">
      <h2 class="font-[--font-display] text-2xl sm:text-3xl font-bold text-[--color-text] mb-5">
        Apply This Verse
      </h2>
      <ApplicationCards client:visible applications={d.applications} questions={d.questions} />
    </section>

    <!-- Bottom navigation -->
    <nav class="flex items-center justify-between pt-8 border-t border-[--color-border]">
      {prev ? (
        <a href={`${import.meta.env.BASE_URL}verse/${chapterNum}/${prev.data.verse}/`}
           class="group flex flex-col items-start max-w-[45%]">
          <span class="text-xs uppercase tracking-[0.2em] text-[--color-text-3] mb-1">Previous</span>
          <span class="font-[--font-display] text-base font-bold text-[--color-text] group-hover:text-[--color-accent] transition-colors">
            Verse {chapterNum}.{prev.data.verse}
          </span>
        </a>
      ) : (
        <a href={`${import.meta.env.BASE_URL}chapter/${chapterNum}/`}
           class="group flex flex-col items-start max-w-[45%]">
          <span class="text-xs uppercase tracking-[0.2em] text-[--color-text-3] mb-1">Back to</span>
          <span class="font-[--font-display] text-base font-bold text-[--color-text] group-hover:text-[--color-accent] transition-colors">
            Chapter {chapterNum}
          </span>
        </a>
      )}
      {next ? (
        <a href={`${import.meta.env.BASE_URL}verse/${chapterNum}/${next.data.verse}/`}
           class="group flex flex-col items-end max-w-[45%]">
          <span class="text-xs uppercase tracking-[0.2em] text-[--color-text-3] mb-1">Next</span>
          <span class="font-[--font-display] text-base font-bold text-[--color-text] group-hover:text-[--color-accent] transition-colors">
            Verse {chapterNum}.{next.data.verse}
          </span>
        </a>
      ) : (
        <a href={`${import.meta.env.BASE_URL}chapter/${chapterNum}/`}
           class="group flex flex-col items-end max-w-[45%]">
          <span class="text-xs uppercase tracking-[0.2em] text-[--color-text-3] mb-1">Back to</span>
          <span class="font-[--font-display] text-base font-bold text-[--color-text] group-hover:text-[--color-accent] transition-colors">
            Chapter {chapterNum}
          </span>
        </a>
      )}
    </nav>

  </main>

</BaseLayout>
