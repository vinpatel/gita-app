---
import BaseLayout from '@layouts/BaseLayout.astro';
import LifeSearch from '@components/islands/LifeSearch.tsx';
import { getCollection } from 'astro:content';

const allShlokas = await getCollection('chapters');
const chaptersWithData = new Set(allShlokas.map((s) => s.data.chapter));

const chapterMeta = [
  { num: 1, name: 'Arjuna\'s Dilemma', verses: 47,
    lesson: 'Inner conflict is the starting point of all growth' },
  { num: 2, name: 'The Path of Knowledge', verses: 72,
    lesson: 'Stop identifying with what changes' },
  { num: 3, name: 'The Path of Action', verses: 43,
    lesson: 'Act without obsessing over results' },
  { num: 4, name: 'Knowledge & Renunciation', verses: 42,
    lesson: 'Knowledge burns karma like fire burns fuel' },
  { num: 5, name: 'Renunciation of Action', verses: 29,
    lesson: 'Be free while fully engaged in the world' },
  { num: 6, name: 'The Path of Meditation', verses: 47,
    lesson: 'The mind is your greatest ally or worst enemy' },
  { num: 7, name: 'Knowledge & Realization', verses: 30,
    lesson: 'One reality in infinite forms' },
  { num: 8, name: 'The Imperishable Absolute', verses: 28,
    lesson: 'Your last thought shapes what comes next' },
  { num: 9, name: 'Royal Knowledge', verses: 34,
    lesson: 'A leaf offered with love reaches the divine' },
  { num: 10, name: 'Divine Manifestations', verses: 42,
    lesson: 'Everything extraordinary is a glimpse of the infinite' },
  { num: 11, name: 'The Cosmic Vision', verses: 55,
    lesson: 'Reality is vaster than the mind can hold' },
  { num: 12, name: 'The Path of Devotion', verses: 20,
    lesson: 'Love is the fastest path' },
  { num: 13, name: 'The Field & The Knower', verses: 35,
    lesson: 'You are the awareness, not the body' },
  { num: 14, name: 'The Three Gunas', verses: 27,
    lesson: 'Clarity, passion, inertia — name them, then rise above' },
  { num: 15, name: 'The Supreme Person', verses: 20,
    lesson: 'Cut the tree of attachment with detachment' },
  { num: 16, name: 'Divine & Demonic Natures', verses: 24,
    lesson: 'Desire, anger, greed — three gates to self-destruction' },
  { num: 17, name: 'Three Kinds of Faith', verses: 28,
    lesson: 'Your faith shapes what you eat, give, and become' },
  { num: 18, name: 'Liberation Through Surrender', verses: 78,
    lesson: 'Surrender everything — then act with full freedom' },
];

const chapters = chapterMeta.map((ch) => ({
  ...ch,
  available: chaptersWithData.has(ch.num),
  loadedVerses: allShlokas.filter((s) => s.data.chapter === ch.num).length,
}));

const totalVerses = allShlokas.length;
---
<BaseLayout title="18 Life Lessons" description="The Bhagavad Gītā — 18 life lessons from a warrior in crisis and his divine friend.">

  <main class="flex-1">

    <!-- Hero -->
    <section class="pt-16 sm:pt-24 pb-8 sm:pb-12 px-6">
      <div class="max-w-4xl mx-auto">
        <h1 class="font-[--font-display] text-[clamp(3rem,8vw,6rem)] font-black leading-[1.0] tracking-tight text-[--color-text]">
          The Bhagavad Gītā
        </h1>
        <p class="mt-4 text-[clamp(1.25rem,3vw,1.75rem)] text-[--color-text-2] leading-snug max-w-2xl">
          18 life lessons from a warrior in crisis and his divine friend.
        </p>
        <p class="mt-2 text-base text-[--color-text-3]">
          {totalVerses} verses &middot; 8 commentary traditions &middot; One search box.
        </p>
      </div>
    </section>

    <!-- Search -->
    <section class="max-w-4xl mx-auto px-6 pb-12">
      <LifeSearch baseUrl={import.meta.env.BASE_URL} compact client:idle />
    </section>

    <!-- 18 Life Lessons — solid color blocks -->
    <section class="pb-0">
      {chapters.map((ch) => (
        ch.available ? (
          <a
            href={`${import.meta.env.BASE_URL}chapter/${ch.num}/`}
            class={`chapter-${ch.num} block group`}
          >
            <div
              class="px-6 py-8 sm:py-10 transition-opacity hover:opacity-90"
              style={`background-color: var(--ch-bg); color: var(--ch-text);`}
            >
              <div class="max-w-4xl mx-auto flex items-start gap-5 sm:gap-8">
                <span class="font-[--font-display] text-[clamp(3rem,6vw,5rem)] font-black leading-none tabular-nums shrink-0 opacity-50">
                  {String(ch.num).padStart(2, '0')}
                </span>
                <div class="min-w-0 pt-1 sm:pt-2">
                  <p class="font-[--font-display] text-[clamp(1.5rem,4vw,2.5rem)] font-black leading-tight">
                    {ch.lesson}
                  </p>
                  <p class="mt-2 text-sm opacity-70">
                    {ch.name} &middot; {ch.loadedVerses < ch.verses ? `${ch.loadedVerses}/${ch.verses}` : ch.verses} verses
                  </p>
                </div>
              </div>
            </div>
          </a>
        ) : (
          <div class={`chapter-${ch.num} block opacity-40`}>
            <div
              class="px-6 py-8 sm:py-10"
              style={`background-color: var(--ch-bg); color: var(--ch-text);`}
            >
              <div class="max-w-4xl mx-auto flex items-start gap-5 sm:gap-8">
                <span class="font-[--font-display] text-[clamp(3rem,6vw,5rem)] font-black leading-none tabular-nums shrink-0 opacity-50">
                  {String(ch.num).padStart(2, '0')}
                </span>
                <div class="min-w-0 pt-1 sm:pt-2">
                  <p class="font-[--font-display] text-[clamp(1.5rem,4vw,2.5rem)] font-black leading-tight">
                    {ch.lesson}
                  </p>
                  <p class="mt-2 text-sm opacity-70">
                    {ch.name} &middot; {ch.verses} verses &middot; Coming soon
                  </p>
                </div>
              </div>
            </div>
          </div>
        )
      ))}
    </section>

    <!-- Features -->
    <section class="bg-[--color-bg] border-t border-[--color-border]">
      <div class="max-w-4xl mx-auto px-6 py-16 sm:py-20">
        <div class="grid sm:grid-cols-3 gap-8 sm:gap-10">
          <div>
            <span class="font-[--font-display] text-[2.5rem] font-black text-[--color-blue]">8</span>
            <h3 class="font-[--font-display] text-lg font-bold mt-1 text-[--color-text]">Commentary Traditions</h3>
            <p class="text-sm text-[--color-text-2] mt-2 leading-relaxed">
              Advaita, Dvaita, Vishishtadvaita, Bhakti, Kashmir Shaivism, Shuddhadvaita, Karma Yoga, Practical Vedanta.
            </p>
          </div>
          <div>
            <span class="font-[--font-display] text-[2.5rem] font-black text-[--color-green]">4</span>
            <h3 class="font-[--font-display] text-lg font-bold mt-1 text-[--color-text]">Life Pillars</h3>
            <p class="text-sm text-[--color-text-2] mt-2 leading-relaxed">
              Personal growth, career, health, and relationships — each verse mapped with reflection questions.
            </p>
          </div>
          <div>
            <span class="font-[--font-display] text-[2.5rem] font-black text-[--color-orange]">14</span>
            <h3 class="font-[--font-display] text-lg font-bold mt-1 text-[--color-text]">Day Sanskrit Course</h3>
            <p class="text-sm text-[--color-text-2] mt-2 leading-relaxed">
              <a href={`${import.meta.env.BASE_URL}learn-sanskrit/`} class="text-[--color-accent] hover:underline">Start the course</a> — read Devanagari and IAST from scratch.
            </p>
          </div>
        </div>
      </div>
    </section>

  </main>

</BaseLayout>
